# Database
DATABASE_URL=
DATABASE_URL_SYNC=

# App
SECRET_KEY=your-secret-key-here
PYTHON_ENV=development

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Twilio発信番号はDB管理するため不要

# Telnyx
TELNYX_API_KEY=KEY01xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELNYX_CONNECTION_ID=xxxxxxxxxxxxxxxxxx

# Redial settings
REDIAL_INTERVAL_SEC=1
MAX_CONCURRENT_CALLS=30

# Webhook base URL (for Twilio/Telnyx callback, e.g. Render URL or ngrok for local dev)
WEBHOOK_BASE_URL=https://your-render-app.onrender.com
